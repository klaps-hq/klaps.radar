# Klaps API
API_URL=http://localhost:5000/api/v2
INTERNAL_API_KEY=your-secret-api-key

# Instagram (required)
INSTAGRAM_ACCESS_TOKEN=your-instagram-token
INSTAGRAM_USER_ID=your-instagram-user-id

# Facebook (optional, jobs are skipped when unset)
FACEBOOK_PAGE_ID=your-facebook-page-id
FACEBOOK_PAGE_ACCESS_TOKEN=your-facebook-page-token

# Threads (optional, job is skipped when unset)
THREADS_USER_ID=your-threads-user-id
THREADS_ACCESS_TOKEN=your-threads-token

# Cron overrides (optional, defaults shown)
# IG_POST_CRON=30 11 * * *
# IG_STORY_CRON=30 8,17 * * *
# FB_POST_CRON=0 13 * * *
# FB_STORY_CRON=45 8,17 * * *
# THREADS_POST_CRON=30 18 * * *

# Tuning (optional, defaults shown)
# STORIES_PER_DAY=2
# PUBLISH_JITTER_MINUTES=0

# Token persistence (optional). When unset, refreshed tokens are written
# back into .env; in Docker these point at files on the /data volume.
# INSTAGRAM_TOKEN_FILE=/data/instagram-token
# THREADS_TOKEN_FILE=/data/threads-token
